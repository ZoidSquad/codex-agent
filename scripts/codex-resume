#!/bin/bash
#
# codex-resume: Resume a previous Codex session
# Usage: codex-resume --project <name> [options] "additional instructions"
#

set -e
set -o pipefail

# ============================================================================
# CONFIGURATION & DETECTION
# ============================================================================

# Detect agent identity from environment or SOUL.md
# Priority: AGENT_NAME env var > OPENCLAW_WORKSPACE/SOUL.md > workspace/SOUL.md > fallback
if [[ -n "$AGENT_NAME" ]]; then
  DETECTED_AGENT="$AGENT_NAME"
else
  # Try to find SOUL.md and extract agent name
  SOUL_FILE=""
  if [[ -n "$OPENCLAW_WORKSPACE" && -f "$OPENCLAW_WORKSPACE/SOUL.md" ]]; then
    SOUL_FILE="$OPENCLAW_WORKSPACE/SOUL.md"
  elif [[ -f "$HOME/.openclaw/workspace-bender/SOUL.md" ]]; then
    SOUL_FILE="$HOME/.openclaw/workspace-bender/SOUL.md"
  elif [[ -f "$HOME/.openclaw/workspace/SOUL.md" ]]; then
    SOUL_FILE="$HOME/.openclaw/workspace/SOUL.md"
  fi
  
  if [[ -n "$SOUL_FILE" ]]; then
    RAW_NAME=$(grep -E "^# SOUL\.md - " "$SOUL_FILE" 2>/dev/null | head -1 | sed 's/^# SOUL\.md - //')
    
    # Check for generic/template titles first
    NORMALIZED=$(echo "$RAW_NAME" | tr '[:upper:]' '[:lower:]')
    if [[ "$NORMALIZED" =~ ^(who you are|who i am|about me|my identity|template|example) ]]; then
      DETECTED_AGENT="Agent"
    elif [[ -n "$RAW_NAME" ]]; then
      # Extract first word as agent name
      DETECTED_AGENT=$(echo "$RAW_NAME" | sed 's/ (.*//' | awk '{print $1}')
    else
      DETECTED_AGENT="Agent"
    fi
  else
    DETECTED_AGENT="Agent"
  fi
fi

AGENT_NAME="${DETECTED_AGENT:-Agent}"
export AGENT_NAME
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"

CODE_BASE="/home/dan/zoidcode"

# Detect workspace
if [[ -n "$OPENCLAW_WORKSPACE" ]]; then
  WORKSPACE_DIR="$OPENCLAW_WORKSPACE"
elif [[ -d "$HOME/.openclaw/workspace-bender" ]]; then
  WORKSPACE_DIR="$HOME/.openclaw/workspace-bender"
elif [[ -d "$HOME/.openclaw/workspace" ]]; then
  WORKSPACE_DIR="$HOME/.openclaw/workspace"
else
  WORKSPACE_DIR="$HOME/.openclaw/workspace"
fi

MEMORY_DIR="$WORKSPACE_DIR/memory"
SESSIONS_FILE="$MEMORY_DIR/codex-sessions.json"
ITERATIONS_FILE="$MEMORY_DIR/codex-iterations.json"

# Defaults
PROJECT=""
PROMPT=""
MODE="workspace-write"
BACKGROUND=false
FORCE=false
TASK_ID=""

# ============================================================================
# DEPENDENCY CHECKS
# ============================================================================

if ! command -v jq &> /dev/null; then
  echo "Error: jq is required but not installed." >&2
  exit 1
fi

if ! command -v codex &> /dev/null; then
  echo "Error: codex CLI not found" >&2
  exit 1
fi

if ! command -v clawd &> /dev/null; then
  HAS_CLAWD=false
else
  HAS_CLAWD=true
fi

check_codex_sandbox_health() {
  if [[ "${CODEX_SKIP_SANDBOX_PREFLIGHT:-0}" == "1" ]]; then
    return 0
  fi

  if [[ "$(uname -s)" != "Linux" ]]; then
    return 0
  fi

  local preflight_output
  if preflight_output=$(codex sandbox linux /bin/true 2>&1); then
    return 0
  fi

  echo "Error: Codex Linux sandbox preflight failed." >&2
  echo "codex-resume is configured for '-a never exec --sandbox workspace-write', but this host cannot start the sandbox." >&2
  echo "Preflight command: codex sandbox linux /bin/true" >&2
  echo "Failure: $preflight_output" >&2
  echo "Common causes: VM/container/AppArmor restrictions blocking the required namespaces." >&2
  echo "Fix host sandbox support or deliberately choose an unsandboxed Codex path outside codex-resume." >&2
  exit 1
}

# ============================================================================
# ARGUMENT PARSING
# ============================================================================

while [[ $# -gt 0 ]]; do
  case $1 in
    --project)
      PROJECT="$2"
      shift 2
      ;;
    --task-id)
      TASK_ID="$2"
      shift 2
      ;;
    --background)
      BACKGROUND=true
      shift
      ;;
    --force)
      FORCE=true
      shift
      ;;
    --full-auto)
      echo "Warning: --full-auto is no longer needed; codex-resume already uses unattended workspace-write sandbox mode." >&2
      shift
      ;;
    --sandbox)
      echo "Warning: --sandbox is now the default behavior for codex-resume." >&2
      shift
      ;;
    --yolo)
      echo "Error: --yolo is no longer supported. codex-resume always runs with -a never --sandbox workspace-write." >&2
      shift
      exit 1
      ;;
    --help|-h)
      echo "Usage: codex-resume --project <name> [options] \"additional instructions\""
      echo ""
      echo "Resumes the last Codex session for the specified project."
      echo "If no additional instructions provided, asks Codex to continue."
      echo ""
      echo "codex-resume always runs Codex with: -a never exec --sandbox workspace-write resume"
      echo ""
      echo "Options:"
      echo "  --project <name>   Project name (required)"
      echo "  --task-id <id>     Mission Control task ID to track with the session"
      echo "  --background       Launch resume in a tracked detached process"
      echo "  --force            Resume even if another Codex run is already active for the project"
      echo ""
      echo "Tracked task workflow:"
      echo "  Use 'codex-branch --project <name> --task-id <id>' before resuming task-bound work."
      echo "  Tracked task work must stay on the branch named exactly like the task ID."
      echo "  --help            Show this help"
      exit 0
      ;;
    *)
      PROMPT="$*"
      break
      ;;
  esac
done

# Validate
if [[ -z "$PROJECT" ]]; then
  echo "Error: --project is required" >&2
  exit 1
fi

# Normalize project name
PROJECT=$(basename "$PROJECT")

# Default prompt
if [[ -z "$PROMPT" ]]; then
  PROMPT="Continue from where you left off. Complete the previous task."
fi

# Check sessions file
if [[ ! -f "$SESSIONS_FILE" ]]; then
  echo "Error: No sessions found. Use 'codex-do' first." >&2
  exit 1
fi

# Get session info from registry
SESSION_DATA=$(jq -c --arg project "$PROJECT" '.[$project] // empty' "$SESSIONS_FILE" 2>/dev/null || echo "")

if [[ -z "$SESSION_DATA" || "$SESSION_DATA" == "null" ]]; then
  echo "Error: No session found for project '$PROJECT'" >&2
  echo "Available projects:" >&2
  jq -r 'keys[]' "$SESSIONS_FILE" >&2
  exit 1
fi

SESSION_ID=$(echo "$SESSION_DATA" | jq -r '.current_session // empty')
LOCAL_SESSION_ID=$(echo "$SESSION_DATA" | jq -r '.tracker.local_session_id // .tracker.session_id // .current_session // "unknown"')
LAST_STATUS=$(echo "$SESSION_DATA" | jq -r '.tracker.status // "unknown"')

if [[ -z "$SESSION_ID" || "$SESSION_ID" == "null" ]]; then
  echo "Error: No session ID found for project '$PROJECT'" >&2
  exit 1
fi

# Setup paths
PROJECT_DIR="$CODE_BASE/$PROJECT"
ZOID_DIR="$PROJECT_DIR/.zoid"
OUTPUT_FILE="$ZOID_DIR/output.txt"
SESSION_TRACKER="$ZOID_DIR/session.json"
TRACKED_TASK_ID=""
TRACKED_BRANCH=""
CURRENT_BRANCH=""

if [[ ! -d "$PROJECT_DIR" ]]; then
  echo "Error: Project directory not found: $PROJECT_DIR" >&2
  exit 1
fi

escape_regex() {
  printf '%s' "$1" | sed 's/[][(){}.^$*+?|\\/]/\\&/g'
}

build_codex_process_pattern() {
  local escaped_output
  escaped_output=$(escape_regex "$OUTPUT_FILE")
  printf '(^|/)codex( |$).*-o[[:space:]]+%s([[:space:]]|$)' "$escaped_output"
}

get_current_branch() {
  if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  git -C "$PROJECT_DIR" symbolic-ref --quiet --short HEAD 2>/dev/null || true
}

load_tracked_metadata() {
  if [[ ! -f "$SESSION_TRACKER" ]]; then
    return 0
  fi

  TRACKED_TASK_ID=$(jq -r '.task_id // empty' "$SESSION_TRACKER" 2>/dev/null || true)
  TRACKED_BRANCH=$(jq -r '.branch // empty' "$SESSION_TRACKER" 2>/dev/null || true)
}

ensure_task_branch_ready() {
  local expected_branch

  load_tracked_metadata

  if [[ -n "$TASK_ID" && -n "$TRACKED_TASK_ID" && "$TASK_ID" != "$TRACKED_TASK_ID" ]]; then
    echo "Error: Requested task '$TASK_ID' does not match tracked task '$TRACKED_TASK_ID' for project '$PROJECT'." >&2
    echo "Resume the existing task or start a new Codex session on the correct task branch." >&2
    exit 1
  fi

  if [[ -z "$TASK_ID" && -n "$TRACKED_TASK_ID" ]]; then
    TASK_ID="$TRACKED_TASK_ID"
  fi

  expected_branch="$TRACKED_BRANCH"
  if [[ -z "$expected_branch" && -n "$TASK_ID" ]]; then
    expected_branch="$TASK_ID"
  fi

  [[ -z "$expected_branch" ]] && return 0

  if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Tracked task work requires a git repository at $PROJECT_DIR." >&2
    echo "Run 'codex-branch --project $PROJECT --task-id $expected_branch' before resuming tracked work." >&2
    exit 1
  fi

  CURRENT_BRANCH=$(get_current_branch)
  if [[ -z "$CURRENT_BRANCH" || "$CURRENT_BRANCH" == "HEAD" ]]; then
    echo "Error: Could not determine the current git branch for $PROJECT_DIR." >&2
    echo "Run 'codex-branch --project $PROJECT --task-id $expected_branch' before resuming tracked work." >&2
    exit 1
  fi

  if [[ "$CURRENT_BRANCH" != "$expected_branch" ]]; then
    echo "Error: Current branch '$CURRENT_BRANCH' does not match tracked task branch '$expected_branch'." >&2
    echo "Run 'codex-branch --project $PROJECT --task-id $expected_branch' before resuming tracked work." >&2
    exit 1
  fi
}

ensure_no_existing_run() {
  local process_pattern running_pids existing_task_id existing_branch

  [[ "$FORCE" == true ]] && return 0

  process_pattern=$(build_codex_process_pattern)
  running_pids=$(pgrep -f "$process_pattern" 2>/dev/null || true)
  if [[ -z "$running_pids" ]]; then
    return 0
  fi

  existing_task_id=""
  existing_branch=""
  if [[ -f "$SESSION_TRACKER" ]]; then
    existing_task_id=$(jq -r '.task_id // empty' "$SESSION_TRACKER" 2>/dev/null || true)
    existing_branch=$(jq -r '.branch // empty' "$SESSION_TRACKER" 2>/dev/null || true)
  fi

  echo "Error: Codex is already running for project '$PROJECT'." >&2
  echo "Use 'codex-status --project $PROJECT --json' to inspect the current session." >&2
  if [[ -n "$existing_task_id" ]]; then
    echo "Tracked task: $existing_task_id" >&2
  fi
  if [[ -n "$existing_branch" ]]; then
    echo "Tracked branch: $existing_branch" >&2
  fi
  echo "Use --force only if you intentionally want overlapping work in the same repo." >&2
  exit 1
}

launch_background_resume() {
  local child_args=()
  local background_pid

  mkdir -p "$ZOID_DIR"

  child_args+=(--project "$PROJECT")
  [[ -n "$TASK_ID" ]] && child_args+=(--task-id "$TASK_ID")
  child_args+=("$PROMPT")

  nohup env \
    AGENT_NAME="$AGENT_NAME" \
    OPENCLAW_WORKSPACE="$WORKSPACE_DIR" \
    CODEX_LAUNCH_MODE="background" \
    "$SCRIPT_PATH" "${child_args[@]}" >/dev/null 2>&1 &
  background_pid=$!

  sleep 1
  if ! kill -0 "$background_pid" 2>/dev/null; then
    echo "Error: background Codex resume launcher exited before the session stabilized." >&2
    echo "Inspect $PROJECT_DIR/.zoid/ and rerun with 'codex-status --project $PROJECT --json'." >&2
    exit 1
  fi

  echo "Started background Codex resume for $PROJECT."
  echo "Launcher PID: $background_pid"
  [[ -n "$TASK_ID" ]] && echo "Task ID: $TASK_ID"
  echo ""
  echo "Next steps:"
  echo "  codex-status --project $PROJECT --json"
  echo "  codex-status --project $PROJECT --output"
  exit 0
}

ensure_task_branch_ready
ensure_no_existing_run
check_codex_sandbox_health

if [[ "$BACKGROUND" == true ]]; then
  launch_background_resume
fi

# Rotate output files before resuming
rotate_output_files() {
  local base_file="$ZOID_DIR/output"
  local max_backups=9
  
  for ((i=max_backups-1; i>=1; i--)); do
    if [[ -f "$base_file-$i.txt" ]]; then
      mv "$base_file-$i.txt" "$base_file-$((i+1)).txt" 2>/dev/null || true
    fi
  done
  
  if [[ -f "$base_file.txt" ]]; then
    mv "$base_file.txt" "$base_file-1.txt" 2>/dev/null || true
  fi
}

rotate_output_files
OUTPUT_FILE="$ZOID_DIR/output.txt"

# ============================================================================
# BUILD FLAGS
# ============================================================================

CODEX_FLAGS="-a never exec --sandbox workspace-write"
CODEX_FLAGS="$CODEX_FLAGS --json"
CODEX_FLAGS="$CODEX_FLAGS -o $OUTPUT_FILE"

# ============================================================================
# EXECUTE
# ============================================================================

echo "═══════════════════════════════════════════════════════════════"
echo "  Codex Resume: $AGENT_NAME"
echo "  Project: $PROJECT"
[[ -n "$CURRENT_BRANCH" ]] && echo "  Branch: $CURRENT_BRANCH"
echo "  Last Status: $LAST_STATUS"
echo "  Session: $SESSION_ID"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "Additional instructions:"
echo "  $PROMPT"
echo ""

# Generate new local session ID for this resume iteration
NEW_LOCAL_SESSION="$(date +%s)-$$-${RANDOM}"

# Create iteration record
ITERATION_FILE="$ZOID_DIR/iteration_${NEW_LOCAL_SESSION}.json"
cat > "$ITERATION_FILE" << EOF
{
  "type": "resume",
  "local_session_id": "$NEW_LOCAL_SESSION",
  "codex_session_id": "$SESSION_ID",
  "timestamp": "$(date -Iseconds)",
  "prompt": $(printf '%s' "$PROMPT" | jq -R -s .),
  "mode": "$MODE"
}
EOF

# Update session tracker
if [[ -f "$SESSION_TRACKER" ]]; then
  jq --arg local_sid "$NEW_LOCAL_SESSION" --arg prompt "$PROMPT" --arg task_id "$TASK_ID" --arg branch "$CURRENT_BRANCH" --arg launch_mode "${CODEX_LAUNCH_MODE:-foreground}" '
    .local_session_id = $local_sid |
    .status = "running" |
    .resumed_at = "'"$(date -Iseconds)"'" |
    .resume_prompt = $prompt |
    .launch_mode = $launch_mode |
    .task_id = (if $task_id == "" then .task_id else $task_id end) |
    .branch = (if $branch == "" then .branch else $branch end)
  ' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
fi

cd "$PROJECT_DIR"

echo "Resuming session..."
echo ""

# Run codex resume
EXIT_CODE=0
if codex $CODEX_FLAGS resume "$SESSION_ID" "$PROMPT" 2>&1 | tee "$OUTPUT_FILE"; then
  EXIT_CODE=${PIPESTATUS[0]}
else
  EXIT_CODE=${PIPESTATUS[0]}
fi

# Determine status
if [[ $EXIT_CODE -eq 0 ]]; then
  STATUS="completed"
  ICON="✅"
else
  STATUS="failed"
  ICON="❌"
fi

# Update tracker
if [[ -f "$SESSION_TRACKER" ]]; then
  jq --arg status "$STATUS" --arg exit "$EXIT_CODE" '
    .status = $status |
    .exit_code = ($exit | tonumber) |
    .completed_at = "'"$(date -Iseconds)"'"
  ' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
fi

# Log skill usage
if [[ "$HAS_CLAWD" == true && $EXIT_CODE -eq 0 ]]; then
  short_prompt=$(printf '%s' "$PROMPT" | cut -c1-80)
  [[ ${#PROMPT} -gt 80 ]] && short_prompt="${short_prompt}..."
  clawd skill used "codex-agent" "Resume project: $PROJECT - $short_prompt" 2>/dev/null || true
fi

# Cleanup old output files
find "$ZOID_DIR" -name "output-*.txt" -type f | sort -r | tail -n +11 | xargs rm -f 2>/dev/null || true

# Show summary
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  Resume Result"
echo "═══════════════════════════════════════════════════════════════"
echo "  Status: $ICON $STATUS"
echo "  Exit Code: $EXIT_CODE"
echo "  Local Session: $NEW_LOCAL_SESSION"
echo "  Output: $OUTPUT_FILE"
echo ""
echo "  Next steps:"
echo "    codex-status --project $PROJECT     # Check status"
echo "    codex-resume --project $PROJECT     # Resume again if needed"
echo "═══════════════════════════════════════════════════════════════"

exit $EXIT_CODE
