#!/bin/bash
#
# codex-status: Check Codex session status and view output
# Usage: codex-status --project <name> [options]
#

set -e

# ============================================================================
# CONFIGURATION & DETECTION
# ============================================================================

# Detect agent identity from environment or SOUL.md
# Priority: AGENT_NAME env var > OPENCLAW_WORKSPACE/SOUL.md > workspace/SOUL.md > fallback
if [[ -n "$AGENT_NAME" ]]; then
  DETECTED_AGENT="$AGENT_NAME"
else
  # Try to find SOUL.md and extract agent name
  SOUL_FILE=""
  if [[ -n "$OPENCLAW_WORKSPACE" && -f "$OPENCLAW_WORKSPACE/SOUL.md" ]]; then
    SOUL_FILE="$OPENCLAW_WORKSPACE/SOUL.md"
  elif [[ -f "$HOME/.openclaw/workspace-bender/SOUL.md" ]]; then
    SOUL_FILE="$HOME/.openclaw/workspace-bender/SOUL.md"
  elif [[ -f "$HOME/.openclaw/workspace/SOUL.md" ]]; then
    SOUL_FILE="$HOME/.openclaw/workspace/SOUL.md"
  fi
  
  if [[ -n "$SOUL_FILE" ]]; then
    RAW_NAME=$(grep -E "^# SOUL\.md - " "$SOUL_FILE" 2>/dev/null | head -1 | sed 's/^# SOUL\.md - //')
    
    # Check for generic/template titles first
    NORMALIZED=$(echo "$RAW_NAME" | tr '[:upper:]' '[:lower:]')
    if [[ "$NORMALIZED" =~ ^(who you are|who i am|about me|my identity|template|example) ]]; then
      DETECTED_AGENT="Agent"
    elif [[ -n "$RAW_NAME" ]]; then
      # Extract first word as agent name
      DETECTED_AGENT=$(echo "$RAW_NAME" | sed 's/ (.*//' | awk '{print $1}')
    else
      DETECTED_AGENT="Agent"
    fi
  else
    DETECTED_AGENT="Agent"
  fi
fi

AGENT_NAME="${DETECTED_AGENT:-Agent}"

CODE_BASE="/home/dan/zoidcode"

# Detect workspace
if [[ -n "$OPENCLAW_WORKSPACE" ]]; then
  WORKSPACE_DIR="$OPENCLAW_WORKSPACE"
elif [[ -d "$HOME/.openclaw/workspace-bender" ]]; then
  WORKSPACE_DIR="$HOME/.openclaw/workspace-bender"
elif [[ -d "$HOME/.openclaw/workspace" ]]; then
  WORKSPACE_DIR="$HOME/.openclaw/workspace"
else
  WORKSPACE_DIR="$HOME/.openclaw/workspace"
fi

MEMORY_DIR="$WORKSPACE_DIR/memory"
ITERATIONS_FILE="$MEMORY_DIR/codex-iterations.json"

# Defaults
PROJECT=""
SHOW_OUTPUT=false
FOLLOW=false
KILL=false
LIST_HISTORY=false
JSON_OUTPUT=false
LIMIT=50

# ============================================================================
# ARGUMENT PARSING
# ============================================================================

while [[ $# -gt 0 ]]; do
  case $1 in
    --project)
      PROJECT="$2"
      shift 2
      ;;
    --output|-o)
      SHOW_OUTPUT=true
      shift
      ;;
    --follow|-f)
      SHOW_OUTPUT=true
      FOLLOW=true
      shift
      ;;
    --kill|-k)
      KILL=true
      shift
      ;;
    --history|-H)
      LIST_HISTORY=true
      shift
      ;;
    --json)
      JSON_OUTPUT=true
      shift
      ;;
    --limit|-n)
      LIMIT="$2"
      shift 2
      ;;
    --help|-h)
      echo "Usage: codex-status --project <name> [options]"
      echo ""
      echo "Options:"
      echo "  --project <name>   Project name (required)"
      echo "  --output, -o       Show session output"
      echo "  --follow, -f       Follow output (like tail -f)"
      echo "  --kill, -k         Kill running session"
      echo "  --history, -H      Show iteration history"
      echo "  --json             Output machine-readable status"
      echo "  --limit <n>, -n    Limit output to N lines (default: 50)"
      echo "  --help, -h         Show this help"
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Validate
if [[ -z "$PROJECT" ]]; then
  echo "Error: --project is required" >&2
  exit 1
fi

if [[ "$JSON_OUTPUT" == true && ( "$SHOW_OUTPUT" == true || "$FOLLOW" == true || "$KILL" == true || "$LIST_HISTORY" == true ) ]]; then
  echo "Error: --json cannot be combined with --output, --follow, --kill, or --history" >&2
  exit 1
fi

# Normalize project name
PROJECT=$(basename "$PROJECT")

# Setup paths
PROJECT_DIR="$CODE_BASE/$PROJECT"
ZOID_DIR="$PROJECT_DIR/.zoid"
OUTPUT_FILE="$ZOID_DIR/output.txt"
SESSION_TRACKER="$ZOID_DIR/session.json"
GIT_BRANCH=""
TRACKED_BRANCH=""
GIT_DIRTY=false

escape_regex() {
  printf '%s' "$1" | sed 's/[][(){}.^$*+?|\\/]/\\&/g'
}

build_codex_process_pattern() {
  local escaped_output
  escaped_output=$(escape_regex "$OUTPUT_FILE")
  printf '(^|/)codex( |$).*-o[[:space:]]+%s([[:space:]]|$)' "$escaped_output"
}

get_current_branch() {
  if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  git -C "$PROJECT_DIR" symbolic-ref --quiet --short HEAD 2>/dev/null || true
}

git_dirty() {
  if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 1
  fi

  [[ -n "$(git -C "$PROJECT_DIR" status --porcelain)" ]]
}

# Check if project exists
if [[ ! -d "$PROJECT_DIR" ]]; then
  echo "Error: Project not found: $PROJECT" >&2
  echo "Expected: $PROJECT_DIR" >&2
  exit 1
fi

GIT_BRANCH=$(get_current_branch)
if git_dirty; then
  GIT_DIRTY=true
fi

# ============================================================================
# KILL MODE
# ============================================================================

if [[ "$KILL" == true ]]; then
  PROCESS_PATTERN=$(build_codex_process_pattern)
  PIDS=$(pgrep -f "$PROCESS_PATTERN" || echo "")
  
  if [[ -n "$PIDS" ]]; then
    echo "Killing Codex processes for $PROJECT:"
    echo "$PIDS" | while read -r pid; do
      echo "  - $pid"
      kill -TERM "$pid" 2>/dev/null || true
    done
    sleep 2
    echo "$PIDS" | while read -r pid; do
      if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid" 2>/dev/null || true
      fi
    done
    echo "Session killed."
  else
    echo "No running Codex processes found for $PROJECT"
  fi
  
  if [[ -f "$SESSION_TRACKER" ]]; then
    jq '.status = "killed" | .killed_at = "'"$(date -Iseconds)"'"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER" 2>/dev/null || true
  fi
  
  exit 0
fi

# ============================================================================
# HISTORY MODE
# ============================================================================

if [[ "$LIST_HISTORY" == true ]]; then
  echo "═══════════════════════════════════════════════════════════════"
  echo "  Iteration History: $PROJECT"
  echo "═══════════════════════════════════════════════════════════════"
  
  if [[ -f "$ITERATIONS_FILE" ]]; then
    ITERATIONS=$(jq -c --arg project "$PROJECT" '.[$project] // []' "$ITERATIONS_FILE" 2>/dev/null || echo "[]")
    COUNT=$(echo "$ITERATIONS" | jq 'length')
    
    if [[ "$COUNT" -eq 0 ]]; then
      echo "  No iteration history found."
    else
      echo "  Total iterations: $COUNT"
      echo ""
      
      # Show last 10 iterations
      echo "$ITERATIONS" | jq -r '.[-10:] | .[] | 
        "────────────────────────────────────────────────────────────\n" +
        "Timestamp: \(.timestamp)\n" +
        "Status: \(.status)\n" +
        "Session: \(.session_id)\n" +
        "Prompt: \(.prompt | .[0:100])\(.prompt | if length > 100 then "..." else "" end)\n"
      '
    fi
  else
    echo "  No iteration history file found."
  fi
  
  echo "═══════════════════════════════════════════════════════════════"
  exit 0
fi

# ============================================================================
# STATUS DISPLAY
# ============================================================================

TRACKER_PRESENT=false
TRACKER_STATUS="unknown"
STATUS="unknown"
SESSION_ID="unknown"
LOCAL_SESSION_ID="unknown"
TASK_ID=""
STARTED="unknown"
COMPLETED="N/A"
EXIT_CODE="N/A"
LAUNCH_MODE="unknown"

if [[ -f "$SESSION_TRACKER" ]]; then
  TRACKER_PRESENT=true
  TRACKER_STATUS=$(jq -r '.status // "unknown"' "$SESSION_TRACKER" 2>/dev/null || echo "unknown")
  STATUS="$TRACKER_STATUS"
  SESSION_ID=$(jq -r '.session_id // "unknown"' "$SESSION_TRACKER" 2>/dev/null || echo "unknown")
  LOCAL_SESSION_ID=$(jq -r '.local_session_id // .session_id // "unknown"' "$SESSION_TRACKER" 2>/dev/null || echo "unknown")
  TASK_ID=$(jq -r '.task_id // empty' "$SESSION_TRACKER" 2>/dev/null || true)
  TRACKED_BRANCH=$(jq -r '.branch // empty' "$SESSION_TRACKER" 2>/dev/null || true)
  STARTED=$(jq -r '.started_at // "unknown"' "$SESSION_TRACKER" 2>/dev/null || echo "unknown")
  COMPLETED=$(jq -r '.completed_at // "N/A"' "$SESSION_TRACKER" 2>/dev/null || echo "N/A")
  EXIT_CODE=$(jq -r '.exit_code // "N/A"' "$SESSION_TRACKER" 2>/dev/null || echo "N/A")
  LAUNCH_MODE=$(jq -r '.launch_mode // "unknown"' "$SESSION_TRACKER" 2>/dev/null || echo "unknown")
fi

[[ -z "$SESSION_ID" ]] && SESSION_ID="unknown"
[[ -z "$LOCAL_SESSION_ID" ]] && LOCAL_SESSION_ID="unknown"
[[ -z "$STARTED" ]] && STARTED="unknown"
[[ -z "$COMPLETED" ]] && COMPLETED="N/A"
[[ -z "$EXIT_CODE" ]] && EXIT_CODE="N/A"
[[ -z "$LAUNCH_MODE" ]] && LAUNCH_MODE="unknown"

PROCESS_PATTERN=$(build_codex_process_pattern)
RUNNING_PIDS=$(pgrep -f "$PROCESS_PATTERN" 2>/dev/null || true)
PROCESS_RUNNING=false
if [[ -n "$RUNNING_PIDS" ]]; then
  PROCESS_RUNNING=true
  STATUS="running"
fi

OUTPUT_EXISTS=false
OUTPUT_AGE_SECONDS=""
OUTPUT_BYTES=""
if [[ -f "$OUTPUT_FILE" ]]; then
  OUTPUT_EXISTS=true
  OUTPUT_MTIME=$(stat -c %Y "$OUTPUT_FILE" 2>/dev/null || echo "")
  OUTPUT_BYTES=$(stat -c %s "$OUTPUT_FILE" 2>/dev/null || echo "")
  if [[ -n "$OUTPUT_MTIME" ]]; then
    NOW_EPOCH=$(date +%s)
    OUTPUT_AGE_SECONDS=$((NOW_EPOCH - OUTPUT_MTIME))
  fi
fi

ACTIVITY_STATE="unknown"
PRODUCTIVE=false
RESUMABLE=false
if [[ "$PROCESS_RUNNING" == true ]]; then
  if [[ "$OUTPUT_EXISTS" == true && -n "$OUTPUT_AGE_SECONDS" ]]; then
    if (( OUTPUT_AGE_SECONDS <= 300 )); then
      ACTIVITY_STATE="active"
      PRODUCTIVE=true
    else
      ACTIVITY_STATE="quiet"
    fi
  else
    ACTIVITY_STATE="starting"
  fi
elif [[ "$STATUS" == "completed" ]]; then
  ACTIVITY_STATE="completed"
elif [[ "$STATUS" == "failed" ]]; then
  ACTIVITY_STATE="failed"
  [[ "$SESSION_ID" != "unknown" && "$SESSION_ID" != "null" ]] && RESUMABLE=true
elif [[ "$STATUS" == "timeout" || "$STATUS" == "killed" ]]; then
  ACTIVITY_STATE="$STATUS"
  [[ "$SESSION_ID" != "unknown" && "$SESSION_ID" != "null" ]] && RESUMABLE=true
elif [[ "$TRACKER_PRESENT" == true ]]; then
  ACTIVITY_STATE="stopped"
  [[ "$SESSION_ID" != "unknown" && "$SESSION_ID" != "null" ]] && RESUMABLE=true
else
  ACTIVITY_STATE="unknown"
fi

if [[ "$JSON_OUTPUT" == true ]]; then
  if [[ -n "$RUNNING_PIDS" ]]; then
    PIDS_JSON=$(printf '%s\n' "$RUNNING_PIDS" | sed '/^$/d' | jq -R . | jq -s .)
  else
    PIDS_JSON='[]'
  fi

  if [[ -n "$OUTPUT_AGE_SECONDS" ]]; then
    OUTPUT_AGE_JSON="$OUTPUT_AGE_SECONDS"
  else
    OUTPUT_AGE_JSON="null"
  fi

  if [[ -n "$OUTPUT_BYTES" ]]; then
    OUTPUT_BYTES_JSON="$OUTPUT_BYTES"
  else
    OUTPUT_BYTES_JSON="null"
  fi

  if [[ "$EXIT_CODE" == "N/A" || "$EXIT_CODE" == "unknown" ]]; then
    EXIT_CODE_JSON="null"
  else
    EXIT_CODE_JSON="$EXIT_CODE"
  fi

  if [[ -n "$GIT_BRANCH" ]]; then
    GIT_BRANCH_JSON=$(printf '%s' "$GIT_BRANCH" | jq -R .)
  else
    GIT_BRANCH_JSON="null"
  fi

  if [[ -n "$TRACKED_BRANCH" ]]; then
    TRACKED_BRANCH_JSON=$(printf '%s' "$TRACKED_BRANCH" | jq -R .)
  else
    TRACKED_BRANCH_JSON="null"
  fi

  if [[ -n "$GIT_BRANCH" && -n "$TRACKED_BRANCH" ]]; then
    if [[ "$GIT_BRANCH" == "$TRACKED_BRANCH" ]]; then
      BRANCH_MATCH_JSON=true
    else
      BRANCH_MATCH_JSON=false
    fi
  else
    BRANCH_MATCH_JSON="null"
  fi

  jq -n \
    --arg project "$PROJECT" \
    --arg directory "$PROJECT_DIR" \
    --arg status "$STATUS" \
    --arg tracker_status "$TRACKER_STATUS" \
    --arg activity_state "$ACTIVITY_STATE" \
    --arg session_id "$SESSION_ID" \
    --arg local_session_id "$LOCAL_SESSION_ID" \
    --arg task_id "$TASK_ID" \
    --arg started_at "$STARTED" \
    --arg completed_at "$COMPLETED" \
    --arg launch_mode "$LAUNCH_MODE" \
    --arg output_file "$OUTPUT_FILE" \
    --argjson tracker_present "$TRACKER_PRESENT" \
    --argjson process_running "$PROCESS_RUNNING" \
    --argjson productive "$PRODUCTIVE" \
    --argjson resumable "$RESUMABLE" \
    --argjson output_exists "$OUTPUT_EXISTS" \
    --argjson output_age_seconds "$OUTPUT_AGE_JSON" \
    --argjson output_bytes "$OUTPUT_BYTES_JSON" \
    --argjson exit_code "$EXIT_CODE_JSON" \
    --argjson pids "$PIDS_JSON" \
    --argjson git_branch "$GIT_BRANCH_JSON" \
    --argjson tracked_branch "$TRACKED_BRANCH_JSON" \
    --argjson branch_match "$BRANCH_MATCH_JSON" \
    --argjson git_dirty "$GIT_DIRTY" '
    {
      project: $project,
      directory: $directory,
      status: $status,
      tracker_status: $tracker_status,
      activity_state: $activity_state,
      tracker_present: $tracker_present,
      process_running: $process_running,
      productive: $productive,
      resumable: $resumable,
      session_id: (if $session_id == "unknown" or $session_id == "null" then null else $session_id end),
      local_session_id: (if $local_session_id == "unknown" or $local_session_id == "null" then null else $local_session_id end),
      task_id: (if $task_id == "" or $task_id == "null" then null else $task_id end),
      started_at: (if $started_at == "unknown" then null else $started_at end),
      completed_at: (if $completed_at == "N/A" or $completed_at == "unknown" then null else $completed_at end),
      exit_code: $exit_code,
      launch_mode: (if $launch_mode == "unknown" then null else $launch_mode end),
      git_branch: $git_branch,
      tracked_branch: $tracked_branch,
      branch_match: $branch_match,
      git_dirty: $git_dirty,
      output: {
        file: $output_file,
        exists: $output_exists,
        age_seconds: $output_age_seconds,
        size_bytes: $output_bytes
      },
      pids: $pids
    }'
  exit 0
fi

echo "═══════════════════════════════════════════════════════════════"
echo "  Codex Status: $PROJECT"
echo "═══════════════════════════════════════════════════════════════"

if [[ "$TRACKER_PRESENT" == true ]]; then
  echo "  Local Session: $LOCAL_SESSION_ID"
  echo "  Codex Session: $SESSION_ID"
  [[ -n "$TASK_ID" ]] && echo "  Task ID: $TASK_ID"
  [[ -n "$TRACKED_BRANCH" ]] && echo "  Tracked Branch: $TRACKED_BRANCH"
  echo "  Status: $STATUS"
  echo "  Activity: $ACTIVITY_STATE"
  [[ "$EXIT_CODE" != "N/A" ]] && echo "  Exit Code: $EXIT_CODE"
  echo "  Started: $STARTED"
  [[ "$COMPLETED" != "N/A" ]] && echo "  Completed: $COMPLETED"
else
  echo "  No session tracker found"
fi

if [[ "$PROCESS_RUNNING" == true ]]; then
  echo "  Process: running (PIDs: $(echo "$RUNNING_PIDS" | tr '\n' ' '))"
else
  echo "  Process: not running"
fi
if [[ "$OUTPUT_EXISTS" == true && -n "$OUTPUT_AGE_SECONDS" ]]; then
  echo "  Output age: ${OUTPUT_AGE_SECONDS}s"
fi

if [[ -d "$ZOID_DIR" ]]; then
  OUTPUT_FILES=$(find "$ZOID_DIR" -name "output*.txt" -type f 2>/dev/null | sort -r)
  if [[ -n "$OUTPUT_FILES" ]]; then
    echo ""
    echo "  Output files:"
    echo "$OUTPUT_FILES" | head -5 | while read -r f; do
      SIZE=$(du -h "$f" 2>/dev/null | cut -f1)
      echo "    - $(basename "$f") ($SIZE)"
    done
  fi
fi

echo ""
echo "  Directory: $PROJECT_DIR"
echo "  Git repo: $([[ -d "$PROJECT_DIR/.git" ]] && echo "yes" || echo "no")"
[[ -n "$GIT_BRANCH" ]] && echo "  Current branch: $GIT_BRANCH"
echo "  Git dirty: $([[ "$GIT_DIRTY" == true ]] && echo "yes" || echo "no")"

if [[ -d "$PROJECT_DIR/.git" ]]; then
  cd "$PROJECT_DIR"
  LAST_COMMIT=$(git log -1 --format="%h %s" 2>/dev/null || echo "none")
  echo "  Last commit: $LAST_COMMIT"
fi

echo "═══════════════════════════════════════════════════════════════"

# ============================================================================
# OUTPUT DISPLAY
# ============================================================================

if [[ "$SHOW_OUTPUT" == true ]]; then
  if [[ ! -f "$OUTPUT_FILE" ]]; then
    echo ""
    echo "No output file found."
    
    # Suggest other output files
    OTHER_OUTPUTS=$(find "$ZOID_DIR" -name "output-*.txt" -type f 2>/dev/null | head -3)
    if [[ -n "$OTHER_OUTPUTS" ]]; then
      echo "Available output files:"
      echo "$OTHER_OUTPUTS"
    fi
    exit 0
  fi
  
  echo ""
  echo "--- Output ($([[ "$FOLLOW" == true ]] && echo "following" || echo "last $LIMIT lines")) ---"
  echo ""
  
  if [[ "$FOLLOW" == true ]]; then
    tail -f "$OUTPUT_FILE"
  else
    tail -n "$LIMIT" "$OUTPUT_FILE"
  fi
fi

# ============================================================================
# HINTS
# ============================================================================

if [[ "$SHOW_OUTPUT" == false && "$KILL" == false && "$LIST_HISTORY" == false ]]; then
  echo ""
  echo "Commands:"
  echo "  codex-status --project $PROJECT --output     # View output"
  echo "  codex-status --project $PROJECT --follow     # Follow live"
  echo "  codex-status --project $PROJECT --history    # View iteration history"
  [[ "$STATUS" == "running" ]] && echo "  codex-status --project $PROJECT --kill       # Kill session"
  echo "  codex-resume --project $PROJECT              # Continue working"
  echo ""
fi
