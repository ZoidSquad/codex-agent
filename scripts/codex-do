#!/bin/bash
#
# codex-do: Main Codex CLI wrapper with session tracking
# Usage: codex-do --project <name> [options] "prompt"
#

set -e

# Agent identity - hardcoded for Bender
AGENT_NAME="Bender"

# Code lives in zoidcode (shared across all agents)
CODE_BASE="/home/dan/zoidcode"

# Session tracking is per-agent (in Bender's workspace memory)
MEMORY_DIR="$HOME/.openclaw/workspace-bender/memory"
SESSIONS_FILE="$MEMORY_DIR/codex-sessions.json"

# Defaults
PROJECT=""
YOLO=false
FULL_AUTO=false
DRY_RUN=false
TIMEOUT=30
PROMPT=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --project)
      PROJECT="$2"
      shift 2
      ;;
    --yolo)
      YOLO=true
      shift
      ;;
    --full-auto)
      FULL_AUTO=true
      shift
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --timeout)
      TIMEOUT="$2"
      shift 2
      ;;
    --help|-h)
      echo "Usage: codex-do --project <name> [options] \"prompt\""
      echo ""
      echo "Options:"
      echo "  --project <name>   Project slug (required)"
      echo "  --yolo            Skip sandbox, auto-approve (dangerous!)"
      echo "  --full-auto       Auto-approve within workspace"
      echo "  --dry-run         Show what would execute"
      echo "  --timeout <min>   Kill after N minutes (default: 30)"
      echo "  --help            Show this help"
      exit 0
      ;;
    *)
      # Remaining args form the prompt
      PROMPT="$*"
      break
      ;;
  esac
done

# Validate
if [[ -z "$PROJECT" ]]; then
  echo "Error: --project is required" >&2
  exit 1
fi

if [[ -z "$PROMPT" ]]; then
  echo "Error: prompt is required" >&2
  exit 1
fi

# Normalize project name: extract basename if full path given
# /home/dan/zoidcode/mission_control_ui -> mission_control_ui
PROJECT=$(basename "$PROJECT")

# Setup paths
PROJECT_DIR="$CODE_BASE/$PROJECT"
ZOID_DIR="$PROJECT_DIR/.zoid"
OUTPUT_FILE="$ZOID_DIR/output.txt"

# Create directories
mkdir -p "$PROJECT_DIR"
mkdir -p "$ZOID_DIR"
mkdir -p "$MEMORY_DIR"

# Initialize sessions file if missing
if [[ ! -f "$SESSIONS_FILE" ]]; then
  echo "{}" > "$SESSIONS_FILE"
fi

# Check if this is a git repo, init if not
if [[ ! -d "$PROJECT_DIR/.git" ]]; then
  echo "Initializing git repository in $PROJECT_DIR..."
  cd "$PROJECT_DIR"
  git init -q
  
  # Create initial .gitignore
  cat > "$PROJECT_DIR/.gitignore" << 'EOF'
# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
EOF
fi

# Check for codex CLI
if ! command -v codex &> /dev/null; then
  echo "Error: codex CLI not found. Install with: npm install -g @openai/codex" >&2
  exit 1
fi

# Build codex flags
CODEX_FLAGS="exec --dangerously-bypass-approvals-and-sandbox"
if [[ "$YOLO" == true ]]; then
  CODEX_FLAGS="$CODEX_FLAGS --yolo"
elif [[ "$FULL_AUTO" == true ]]; then
  CODEX_FLAGS="$CODEX_FLAGS --full-auto"
fi

# Add JSON output for session ID extraction
CODEX_FLAGS="$CODEX_FLAGS --json"

# Add output file
CODEX_FLAGS="$CODEX_FLAGS -o $OUTPUT_FILE"

# Calculate timeout in seconds
TIMEOUT_SEC=$((TIMEOUT * 60))

# Create session tracking file
SESSION_TRACKER="$ZOID_DIR/session.json"
cat > "$SESSION_TRACKER" << EOF
{
  "project": "$PROJECT",
  "agent": "$AGENT_NAME",
  "started_at": "$(date -Iseconds)",
  "prompt": $(echo "$PROMPT" | jq -R -s .),
  "status": "running",
  "flags": {
    "yolo": $YOLO,
    "full_auto": $FULL_AUTO
  }
}
EOF

# Show what we're doing
echo "═══════════════════════════════════════════════════════════════"
echo "  Codex Agent: $AGENT_NAME"
echo "  Project: $PROJECT"
echo "  Directory: $PROJECT_DIR"
echo "  Timeout: ${TIMEOUT} minutes"
echo "  Mode: $([[ $YOLO == true ]] && echo 'YOLO (no sandbox)' || ([[ $FULL_AUTO == true ]] && echo 'Full Auto' || echo 'Sandbox'))"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "Prompt:"
echo "  $PROMPT"
echo ""

if [[ "$DRY_RUN" == true ]]; then
  echo "[DRY RUN] Would execute:"
  echo "  cd $PROJECT_DIR"
  echo "  timeout ${TIMEOUT_SEC}s codex $CODEX_FLAGS $(echo "$PROMPT" | jq -R -s .)"
  exit 0
fi

# Run codex
echo "Starting Codex session..."
echo ""

cd "$PROJECT_DIR"

# Run with timeout and capture JSON output
JSON_OUTPUT=$(mktemp)
if timeout "$TIMEOUT_SEC" codex $CODEX_FLAGS "$PROMPT" 2>&1 | tee "$OUTPUT_FILE"; then
  EXIT_CODE=$?
else
  EXIT_CODE=$?
fi

# Check if we got a session ID from the JSON output
SESSION_ID=""
if [[ -f "$OUTPUT_FILE" ]]; then
  # Try to extract session ID from first line (JSON format)
  SESSION_ID=$(head -1 "$OUTPUT_FILE" | jq -r '.session_id // empty' 2>/dev/null || echo "")
fi

# Update session tracker
if [[ -n "$SESSION_ID" ]]; then
  jq --arg sid "$SESSION_ID" '.session_id = $sid' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
fi

# Log skill usage to Mission Control
log_skill_action() {
  local status=$1
  local project=$2
  local prompt="$3"
  # Truncate prompt for logging
  local short_prompt=$(echo "$prompt" | cut -c1-80)
  if [[ ${#prompt} -gt 80 ]]; then
    short_prompt="${short_prompt}..."
  fi
  
  # Log via clawd CLI using 'skill used' for proper action type (suppress errors - don't break main flow)
  /usr/bin/env node ~/clawd-team/clawd-cli.js skill used "codex-agent" "Project: $project - $short_prompt" 2>/dev/null || true
}

# Update status based on exit code
if [[ $EXIT_CODE -eq 0 ]]; then
  jq '.status = "completed" | .completed_at = "'$(date -Iseconds)'"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
  echo ""
  echo "✅ Codex session completed successfully"
  # Log the skill usage
  log_skill_action "completed" "$PROJECT" "$PROMPT"
elif [[ $EXIT_CODE -eq 124 ]]; then
  jq '.status = "timeout" | .completed_at = "'$(date -Iseconds)'"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
  echo ""
  echo "⏱️  Codex session timed out after ${TIMEOUT} minutes"
  echo "   Use: codex-resume --project $PROJECT \"Continue from where you left off\""
else
  jq '.status = "failed" | .exit_code = '$EXIT_CODE' | .completed_at = "'$(date -Iseconds)'"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
  echo ""
  echo "❌ Codex session failed with exit code $EXIT_CODE"
fi

# Update sessions registry
TMP_FILE=$(mktemp)
jq --arg proj "$PROJECT" --arg sid "$SESSION_ID" --arg track "$(cat "$SESSION_TRACKER")" '
  .[$proj] = {
    "current_session": $sid,
    "last_updated": "'$(date -Iseconds)'",
    "tracker": ($track | fromjson)
  }
' "$SESSIONS_FILE" > "$TMP_FILE" && mv "$TMP_FILE" "$SESSIONS_FILE"

# Show summary
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  Session Summary"
echo "═══════════════════════════════════════════════════════════════"
echo "  Session ID: ${SESSION_ID:-unknown}"
echo "  Status: $(jq -r '.status' "$SESSION_TRACKER")"
echo "  Output: $OUTPUT_FILE"
echo ""
echo "  Next steps:"
echo "    codex-status --project $PROJECT     # Check status"
echo "    codex-resume --project $PROJECT     # Continue working"
echo "═══════════════════════════════════════════════════════════════"

exit $EXIT_CODE
