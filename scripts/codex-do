#!/bin/bash
#
# codex-do: Main Codex CLI wrapper with session tracking
# Usage: codex-do --project <name> [options] "prompt"
#

set -e
set -o pipefail  # FIX: Capture correct exit code from piped commands

# ============================================================================
# CONFIGURATION & DETECTION
# ============================================================================

# Detect agent identity from environment or SOUL.md
# Priority: AGENT_NAME env var > OPENCLAW_WORKSPACE/SOUL.md > workspace/SOUL.md > fallback
if [[ -n "$AGENT_NAME" ]]; then
  DETECTED_AGENT="$AGENT_NAME"
else
  # Try to find SOUL.md and extract agent name
  # Respect OPENCLAW_WORKSPACE if set
  SOUL_FILE=""
  if [[ -n "$OPENCLAW_WORKSPACE" && -f "$OPENCLAW_WORKSPACE/SOUL.md" ]]; then
    SOUL_FILE="$OPENCLAW_WORKSPACE/SOUL.md"
  elif [[ -f "$HOME/.openclaw/workspace-bender/SOUL.md" ]]; then
    SOUL_FILE="$HOME/.openclaw/workspace-bender/SOUL.md"
  elif [[ -f "$HOME/.openclaw/workspace/SOUL.md" ]]; then
    SOUL_FILE="$HOME/.openclaw/workspace/SOUL.md"
  fi
  
  if [[ -n "$SOUL_FILE" ]]; then
    # Look for "# SOUL.md - Name" pattern, extract just the name
    # Example: "# SOUL.md - Bender (Developer)" -> "Bender"
    # Example: "# SOUL.md - Who You Are" -> "Agent" (fallback for generic titles)
    RAW_NAME=$(grep -E "^# SOUL\.md - " "$SOUL_FILE" 2>/dev/null | head -1 | sed 's/^# SOUL\.md - //')
    
    # Check for generic/template titles first
    NORMALIZED=$(echo "$RAW_NAME" | tr '[:upper:]' '[:lower:]')
    if [[ "$NORMALIZED" =~ ^(who you are|who i am|about me|my identity|template|example) ]]; then
      DETECTED_AGENT="Agent"
    elif [[ -n "$RAW_NAME" ]]; then
      # Extract first word as agent name (handles "Bender (Developer)" -> "Bender")
      DETECTED_AGENT=$(echo "$RAW_NAME" | sed 's/ (.*//' | awk '{print $1}')
    else
      DETECTED_AGENT="Agent"
    fi
  else
    DETECTED_AGENT="Agent"
  fi
fi

AGENT_NAME="${DETECTED_AGENT:-Agent}"
export AGENT_NAME

# Code lives in zoidcode (shared across all agents)
CODE_BASE="/home/dan/zoidcode"

# Session tracking is per-agent (in agent's workspace memory)
# Detect workspace from environment or default
if [[ -n "$OPENCLAW_WORKSPACE" ]]; then
  WORKSPACE_DIR="$OPENCLAW_WORKSPACE"
elif [[ -d "$HOME/.openclaw/workspace-bender" ]]; then
  WORKSPACE_DIR="$HOME/.openclaw/workspace-bender"
elif [[ -d "$HOME/.openclaw/workspace" ]]; then
  WORKSPACE_DIR="$HOME/.openclaw/workspace"
else
  WORKSPACE_DIR="$HOME/.openclaw/workspace"
fi

MEMORY_DIR="$WORKSPACE_DIR/memory"
SESSIONS_FILE="$MEMORY_DIR/codex-sessions.json"
ITERATIONS_FILE="$MEMORY_DIR/codex-iterations.json"

# Settings
MAX_SESSIONS_PER_PROJECT=50  # Keep last N sessions per project
MAX_ITERATIONS=1000          # Total iterations to keep across all projects

# ============================================================================
# DEPENDENCY CHECKS
# ============================================================================

# Check for jq
if ! command -v jq &> /dev/null; then
  echo "Error: jq is required but not installed. Install with: sudo apt-get install jq" >&2
  exit 1
fi

# Check for flock (file locking)
if ! command -v flock &> /dev/null; then
  echo "Warning: flock not available. Session registry may have race conditions." >&2
  HAS_FLOCK=false
else
  HAS_FLOCK=true
fi

# Check for codex CLI
if ! command -v codex &> /dev/null; then
  echo "Error: codex CLI not found. Install with: npm install -g @openai/codex" >&2
  exit 1
fi

# Check for Mission Control CLI
if ! command -v clawd &> /dev/null; then
  echo "Error: clawd CLI not found in PATH. Mission Control integration unavailable." >&2
  HAS_CLAWD=false
else
  HAS_CLAWD=true
fi

# ============================================================================
# ARGUMENT PARSING
# ============================================================================

# Defaults
PROJECT=""
DRY_RUN=false
SUGGEST_CMD=false
TIMEOUT=30
VALIDATE_PROJECT=true
PROMPT=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --project)
      PROJECT="$2"
      shift 2
      ;;
    --full-auto)
      echo "Warning: --full-auto is no longer needed; codex-do already uses unattended workspace-write sandbox mode." >&2
      shift
      ;;
    --yolo)
      echo "Error: --yolo is no longer supported. codex-do always runs with -a never --sandbox workspace-write." >&2
      shift
      exit 1
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --suggest-cmd)
      SUGGEST_CMD=true
      shift
      ;;
    --no-validate)
      VALIDATE_PROJECT=false
      shift
      ;;
    --timeout)
      TIMEOUT="$2"
      shift 2
      ;;
    --help|-h)
      echo "Usage: codex-do --project <name> [options] \"prompt\""
      echo ""
      echo "codex-do always runs Codex with: -a never exec --sandbox workspace-write"
      echo ""
      echo "Options:"
      echo "  --project <name>   Project slug (required)"
      echo "  --dry-run         Show what would execute"
      echo "  --suggest-cmd     Output OpenClaw exec command for background mode"
      echo "  --no-validate     Skip Mission Control project validation"
      echo "  --timeout <min>   Kill after N minutes (0 = no timeout, default: 30)"
      echo "  --help            Show this help"
      echo ""
      echo "Environment:"
      echo "  AGENT_NAME        Override detected agent name"
      echo "  OPENCLAW_WORKSPACE  Override workspace directory"
      exit 0
      ;;
    *)
      # Remaining args form the prompt
      PROMPT="$*"
      break
      ;;
  esac
done

# Validate
if [[ -z "$PROJECT" ]]; then
  echo "Error: --project is required" >&2
  exit 1
fi

if [[ -z "$PROMPT" ]]; then
  echo "Error: prompt is required" >&2
  exit 1
fi

# Normalize project name
PROJECT=$(basename "$PROJECT")

# ============================================================================
# MISSION CONTROL VALIDATION
# ============================================================================

validate_project_in_mc() {
  if [[ "$VALIDATE_PROJECT" == false ]]; then
    return 0
  fi
  
  if [[ "$HAS_CLAWD" == false ]]; then
    echo "Warning: Cannot validate project - clawd not available" >&2
    return 0
  fi
  
  # Check if project exists in Mission Control
  if ! clawd project list --json 2>/dev/null | jq -e ".[] | select(.name == \"$PROJECT\" or .folder == \"$PROJECT\")" > /dev/null 2>&1; then
    echo "Error: Project '$PROJECT' not found in Mission Control." >&2
    echo "Run 'clawd project list' to see available projects." >&2
    echo "Use --no-validate to skip this check." >&2
    exit 1
  fi
}

validate_project_in_mc

# ============================================================================
# SUGGEST-CMD MODE
# ============================================================================

if [[ "$SUGGEST_CMD" == true ]]; then
  # Keep the recommended OpenClaw command aligned with the single supported mode.
  SUGGEST_FLAGS="-a never exec --sandbox workspace-write"
  SUGGEST_FLAGS="$SUGGEST_FLAGS --json"
  
  PROJECT_DIR="$CODE_BASE/$PROJECT"
  
  echo "═══════════════════════════════════════════════════════════════"
  echo "  OpenClaw Exec Command (for background mode with PTY)"
  echo "═══════════════════════════════════════════════════════════════"
  echo ""
  echo "Run this to start Codex with PTY and background mode:"
  echo ""
  echo "exec pty:true background:true workdir:$PROJECT_DIR \\"
  echo "  command:\"codex $SUGGEST_FLAGS -o .zoid/output.txt \\"
  echo "    $(echo "$PROMPT" | jq -R -s . | sed 's/\\"/\\\\\\"/g')\""
  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo ""
  echo "After running, store the sessionId:"
  echo "  echo '{\"openclaw_session_id\":\"SESSION_ID_HERE\"}' > \\"
  echo "    $PROJECT_DIR/.zoid/openclaw-session.json"
  echo ""
  exit 0
fi

# ============================================================================
# SETUP DIRECTORIES
# ============================================================================

PROJECT_DIR="$CODE_BASE/$PROJECT"
ZOID_DIR="$PROJECT_DIR/.zoid"

# Create directories
mkdir -p "$PROJECT_DIR"
mkdir -p "$ZOID_DIR"
mkdir -p "$MEMORY_DIR"

# Initialize session files if missing
if [[ ! -f "$SESSIONS_FILE" ]]; then
  echo "{}" > "$SESSIONS_FILE"
fi

if [[ ! -f "$ITERATIONS_FILE" ]]; then
  echo "{}" > "$ITERATIONS_FILE"
fi

# ============================================================================
# OUTPUT FILE ROTATION
# ============================================================================

# Rotate output files to preserve history
# output.txt -> output-1.txt -> output-2.txt -> ... (shifting)
rotate_output_files() {
  local base_file="$ZOID_DIR/output"
  local max_backups=9
  
  # Shift existing backups
  for ((i=max_backups-1; i>=1; i--)); do
    if [[ -f "$base_file-$i.txt" ]]; then
      mv "$base_file-$i.txt" "$base_file-$((i+1)).txt" 2>/dev/null || true
    fi
  done
  
  # Move current output to backup 1
  if [[ -f "$base_file.txt" ]]; then
    mv "$base_file.txt" "$base_file-1.txt" 2>/dev/null || true
  fi
}

rotate_output_files
OUTPUT_FILE="$ZOID_DIR/output.txt"

# ============================================================================
# GIT INITIALIZATION
# ============================================================================

init_git_repo() {
  if [[ ! -d "$PROJECT_DIR/.git" ]]; then
    echo "Initializing git repository in $PROJECT_DIR..."
    cd "$PROJECT_DIR"
    git init -q
    
    # Create minimal .gitignore (not opinionated)
    if [[ ! -f "$PROJECT_DIR/.gitignore" ]]; then
      cat > "$PROJECT_DIR/.gitignore" << 'EOF'
# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Testing
coverage/
EOF
    fi
  fi
}

init_git_repo

# ============================================================================
# SESSION REGISTRY HELPERS (with locking)
# ============================================================================

# Update sessions registry with file locking
update_sessions_registry() {
  local project="$1"
  local session_id="$2"
  local tracker_data="$3"
  
  local update_cmd="
    import json, sys
    data = json.load(sys.stdin)
    data['$project'] = {
      'current_session': '$session_id',
      'last_updated': '$(date -Iseconds)',
      'tracker': $tracker_data
    }
    
    # Keep only last $MAX_SESSIONS_PER_PROJECT projects to prevent bloat
    if len(data) > $MAX_SESSIONS_PER_PROJECT:
      # Sort by last_updated and keep most recent
      sorted_items = sorted(
        data.items(),
        key=lambda x: x[1].get('last_updated', ''),
        reverse=True
      )
      data = dict(sorted_items[:$MAX_SESSIONS_PER_PROJECT])
    
    json.dump(data, sys.stdout, indent=2)
  "
  
  if [[ "$HAS_FLOCK" == true ]]; then
    (
      flock -x 200
      python3 -c "$update_cmd" < "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp" && \
        mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
    ) 200>"$SESSIONS_FILE.lock"
  else
    python3 -c "$update_cmd" < "$SESSIONS_FILE" > "$SESSIONS_FILE.tmp" && \
      mv "$SESSIONS_FILE.tmp" "$SESSIONS_FILE"
  fi
}

# Add to iteration history
add_iteration_history() {
  local project="$1"
  local session_id="$2"
  local status="$3"
  local prompt="$4"
  
  local iteration_entry="{
    \"session_id\": \"$session_id\",
    \"timestamp\": \"$(date -Iseconds)\",
    \"status\": \"$status\",
    \"prompt\": $(echo "$prompt" | jq -R -s .)
  }"
  
  local update_cmd="
    import json, sys
    data = json.load(sys.stdin)
    if '$project' not in data:
      data['$project'] = []
    data['$project'].append($iteration_entry)
    
    # Keep only last 100 iterations per project
    if len(data['$project']) > 100:
      data['$project'] = data['$project'][-100:]
    
    # Also enforce total limit
    total = sum(len(v) for v in data.values())
    if total > $MAX_ITERATIONS:
      # Remove oldest from each project proportionally
      while total > $MAX_ITERATIONS:
        for proj in list(data.keys()):
          if data[proj]:
            data[proj].pop(0)
            total -= 1
            if total <= $MAX_ITERATIONS:
              break
    
    json.dump(data, sys.stdout, indent=2)
  "
  
  if [[ "$HAS_FLOCK" == true ]]; then
    (
      flock -x 200
      python3 -c "$update_cmd" < "$ITERATIONS_FILE" > "$ITERATIONS_FILE.tmp" && \
        mv "$ITERATIONS_FILE.tmp" "$ITERATIONS_FILE"
    ) 200>"$ITERATIONS_FILE.lock"
  else
    python3 -c "$update_cmd" < "$ITERATIONS_FILE" > "$ITERATIONS_FILE.tmp" && \
      mv "$ITERATIONS_FILE.tmp" "$ITERATIONS_FILE"
  fi
}

# ============================================================================
# SKILL LOGGING
# ============================================================================

log_skill_action() {
  local status="$1"
  local project="$2"
  local prompt="$3"
  
  if [[ "$HAS_CLAWD" == false ]]; then
    return 0
  fi
  
  local short_prompt
  short_prompt=$(echo "$prompt" | cut -c1-80)
  if [[ ${#prompt} -gt 80 ]]; then
    short_prompt="${short_prompt}..."
  fi
  
  # Use clawd command (globally available)
  clawd skill used "codex-agent" "Project: $project - $short_prompt" 2>/dev/null || true
}

# ============================================================================
# BUILD & EXECUTE
# ============================================================================

# Build codex flags for the single supported execution mode.
CODEX_FLAGS="-a never exec --sandbox workspace-write"
CODEX_FLAGS="$CODEX_FLAGS --json"
CODEX_FLAGS="$CODEX_FLAGS -o $OUTPUT_FILE"

# Calculate timeout
if [[ "$TIMEOUT" -eq 0 ]]; then
  TIMEOUT_CMD=""
  TIMEOUT_DISPLAY="No timeout"
else
  TIMEOUT_SEC=$((TIMEOUT * 60))
  TIMEOUT_CMD="timeout $TIMEOUT_SEC"
  TIMEOUT_DISPLAY="${TIMEOUT} minutes"
fi

# Generate unique session ID
SESSION_ID="$(date +%s)-$$-${RANDOM}"

# Create session tracking file
SESSION_TRACKER="$ZOID_DIR/session.json"
cat > "$SESSION_TRACKER" << EOF
{
  "session_id": "$SESSION_ID",
  "project": "$PROJECT",
  "agent": "$AGENT_NAME",
  "started_at": "$(date -Iseconds)",
  "prompt": $(echo "$PROMPT" | jq -R -s .),
  "status": "running",
  "flags": {
    "approval_policy": "never",
    "sandbox": "workspace-write"
  }
}
EOF

# Show what we're doing
MODE_LABEL="Unattended workspace-write sandbox"

echo "═══════════════════════════════════════════════════════════════"
echo "  Codex Agent: $AGENT_NAME"
echo "  Project: $PROJECT"
echo "  Directory: $PROJECT_DIR"
echo "  Timeout: $TIMEOUT_DISPLAY"
echo "  Mode: $MODE_LABEL"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "Prompt:"
echo "  $PROMPT"
echo ""

if [[ "$DRY_RUN" == true ]]; then
  echo "[DRY RUN] Would execute:"
  echo "  cd $PROJECT_DIR"
  echo "  $TIMEOUT_CMD codex $CODEX_FLAGS $(echo "$PROMPT" | jq -R -s .)"
  exit 0
fi

# Run codex
echo "Starting Codex session..."
echo "Session ID: $SESSION_ID"
echo ""

cd "$PROJECT_DIR"

# Run with timeout and capture output
# FIX: Use pipefail to get correct exit code
EXIT_CODE=0
if $TIMEOUT_CMD codex $CODEX_FLAGS "$PROMPT" 2>&1 | tee "$OUTPUT_FILE"; then
  EXIT_CODE=${PIPESTATUS[0]}
else
  EXIT_CODE=${PIPESTATUS[0]}
fi

# Extract Codex session ID from output if available
CODEX_SESSION_ID=""
if [[ -f "$OUTPUT_FILE" ]]; then
  CODEX_SESSION_ID=$(head -1 "$OUTPUT_FILE" | jq -r '.session_id // empty' 2>/dev/null || echo "")
fi

# Update session tracker with results
jq --arg sid "$CODEX_SESSION_ID" --arg exit "$EXIT_CODE" '
  .session_id = $sid |
  .exit_code = ($exit | tonumber) |
  .completed_at = "'$(date -Iseconds)'"
' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"

# Determine final status
FINAL_STATUS="unknown"
if [[ $EXIT_CODE -eq 0 ]]; then
  FINAL_STATUS="completed"
  jq '.status = "completed"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
  echo ""
  echo "✅ Codex session completed successfully"
  log_skill_action "completed" "$PROJECT" "$PROMPT"
elif [[ $EXIT_CODE -eq 124 ]]; then
  FINAL_STATUS="timeout"
  jq '.status = "timeout"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
  echo ""
  echo "⏱️  Codex session timed out after $TIMEOUT_DISPLAY"
  echo "   Use: codex-resume --project $PROJECT \"Continue from where you left off\""
  log_skill_action "timeout" "$PROJECT" "$PROMPT"
else
  FINAL_STATUS="failed"
  jq '.status = "failed"' "$SESSION_TRACKER" > "$SESSION_TRACKER.tmp" && mv "$SESSION_TRACKER.tmp" "$SESSION_TRACKER"
  echo ""
  echo "❌ Codex session failed with exit code $EXIT_CODE"
  log_skill_action "failed" "$PROJECT" "$PROMPT"
fi

# Update registries
TRACKER_DATA=$(cat "$SESSION_TRACKER" | jq -c .)
update_sessions_registry "$PROJECT" "$CODEX_SESSION_ID" "$TRACKER_DATA"
add_iteration_history "$PROJECT" "$SESSION_ID" "$FINAL_STATUS" "$PROMPT"

# Cleanup old output files (keep last 10)
find "$ZOID_DIR" -name "output-*.txt" -type f | sort -r | tail -n +11 | xargs rm -f 2>/dev/null || true

# Show summary
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  Session Summary"
echo "═══════════════════════════════════════════════════════════════"
echo "  Session ID: ${SESSION_ID}"
echo "  Codex Session: ${CODEX_SESSION_ID:-N/A}"
echo "  Status: $FINAL_STATUS"
echo "  Exit Code: $EXIT_CODE"
echo "  Output: $OUTPUT_FILE"
echo ""
echo "  Next steps:"
echo "    codex-status --project $PROJECT     # Check status"
echo "    codex-resume --project $PROJECT     # Continue working"
echo "═══════════════════════════════════════════════════════════════"

exit $EXIT_CODE
